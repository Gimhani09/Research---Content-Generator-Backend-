# Environment Configuration
# Copy this file to .env and configure your settings

# Model Settings (all FREE and LOCAL)
MODEL_CACHE_DIR=./models
USE_GPU=true  # Set to false if no GPU available

# Content Generation Models
ENGLISH_MODEL=meta-llama/Llama-3.2-3B-Instruct  # or gpt2-medium
SINHALA_MODEL=google/mt5-base  # Supports Sinhala natively
USE_4BIT_QUANTIZATION=true  # Reduce memory usage

# Image Generation
IMAGE_MODEL=stabilityai/stable-diffusion-2-1  # or CompVis/stable-diffusion-v1-4
USE_IMAGE_AI=false  # Set true for AI images, false for HTML posters
IMAGE_STEPS=20  # Lower = faster but lower quality

# Fine-tuning Settings
FINETUNE_OUTPUT_DIR=./finetuned_models
FINETUNE_BATCH_SIZE=4
FINETUNE_LEARNING_RATE=2e-4
FINETUNE_EPOCHS=3

# Server Settings
HOST=0.0.0.0
PORT=8000
